# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Polygon.io API Configuration
POLYGON_API_KEY=your_polygon_api_key_here

# API Settings
POLYGON_BASE_URL=https://api.polygon.io
POLYGON_RATE_LIMIT=unlimited

# Data Cache Settings
CACHE_DIRECTORY=./cache
CACHE_EXPIRY_DAYS=7

# Backtesting Parameters
DEFAULT_INITIAL_CAPITAL=100000
DEFAULT_POSITION_SIZE_PCT=10
DEFAULT_MAX_POSITIONS=10

# Short Selling Costs (adjustable per test)
DEFAULT_BORROW_RATE_ANNUAL=0.05
DEFAULT_HARD_TO_BORROW_RATE=0.25
DEFAULT_SLIPPAGE_BPS=50

# Risk Management
DEFAULT_STOP_LOSS_PCT=0.15
DEFAULT_TAKE_PROFIT_PCT=0.05
MARGIN_REQUIREMENT=1.5
MAINTENANCE_MARGIN=1.25

# Screening Criteria Defaults
MIN_GAP_UP_PCT=5.0
MAX_GAP_UP_PCT=100.0
MIN_PREMARKET_VOLUME=10000
MAX_MARKET_CAP=300000000
MIN_PRICE=1.0
MAX_PRICE=20.0

# Data Granularity
USE_MINUTE_BARS=true
MINUTE_BAR_INTERVAL=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=backtesting.log